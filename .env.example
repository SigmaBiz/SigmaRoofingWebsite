# Environment Configuration
NODE_ENV=production
PORT=3000

# Database Configuration (PostgreSQL with Neon)
DATABASE_URL=postgresql://username:password@host/database

# Session Configuration
SESSION_SECRET=your-secure-session-secret-here

# Google API Configuration - REQUIRED for MVP3
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable: Places API (New), Geocoding API
GOOGLE_API_KEY=your_google_places_api_key_here

# SendGrid Email Service - REQUIRED for MVP3  
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Email Configuration
FROM_EMAIL=noreply@sigmaroofing.com
TO_EMAIL=contact@sigmaroofing.com
NOTIFICATION_EMAIL=your_email@example.com

# Cloudinary Configuration (for image storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-app.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Optional: Google OAuth for Photos (admin panel)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Optional: SMTP Configuration (alternative to SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Optional: Calendly Integration
CALENDLY_URL=https://calendly.com/your-username

# Optional: API Configuration
API_BASE_URL=http://localhost:3000

# Feature Flags
ENABLE_ADMIN_PANEL=true
ENABLE_DEBUG_PANEL=false